# ── Backend Environment Variables ────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# PostgreSQL connection string (Neon or local)
# Neon example: postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/stellaride?sslmode=require
DATABASE_URL=postgresql://stellaride_user:secure_password@localhost:5432/stellaride

# JWT signing secret — must be at least 32 characters, random string
JWT_SECRET=change-me-to-a-random-string-of-at-least-32-characters

# How long JWT tokens stay valid (hours)
JWT_EXPIRY_HOURS=24

# Server port
PORT=8080

# Log level: error | warn | info | debug | trace
RUST_LOG=backend=debug,tower_http=info

# ─── OAuth (optional) ─────────────────────────────────────────────────────────
# GitHub OAuth — create an app at https://github.com/settings/developers
# Callback URL: http://localhost:8080/api/v1/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth — create credentials at https://console.cloud.google.com/
# Authorised redirect URI: http://localhost:8080/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Frontend base URL — used to redirect users after OAuth (e.g. http://localhost:5173)
FRONTEND_URL=http://localhost:5173

# ─── AI Chat (optional) ────────────────────────────────────────────────────────
# Groq API key — get one free at https://console.groq.com
# Used by the /api/v1/ai/chat endpoint to power StellarAI in the IDE
GROQ_API_KEY=
# Supported Groq model (default avoids deprecated llama3-8b-8192)
GROQ_MODEL=llama-3.1-8b-instant

# ─── Soroban Tooling ────────────────────────────────────────────────────────────
# Execution mode for compile/test/audit: docker | local
SOROBAN_EXECUTION_MODE=docker
# Docker image used for sandboxed command execution
SOROBAN_DOCKER_IMAGE=stellaride/soroban-sandbox:latest
# Command timeout in seconds
SOROBAN_TIMEOUT_SECONDS=180
# soroban-sdk version used for generated Cargo.toml in IDE workspaces
SOROBAN_SDK_VERSION=22.0.5
# Deploy configuration
SOROBAN_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_CLI_PATH=soroban
# Optional source account secret for backend CLI deployment flow
SOROBAN_DEPLOY_SECRET_KEY=
# Audit command executed inside sandbox
SOROBAN_AUDIT_COMMAND=cargo scout-audit
