# ── Frontend Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Variables prefixed with VITE_ are exposed to the browser bundle.

# URL of the StellarIDE backend API (with or without /api/v1 suffix)
VITE_API_URL=http://localhost:8080

# Application display name (used in page titles / meta)
VITE_APP_NAME=StellarIDE

# Stellar network to target: TESTNET | MAINNET | FUTURENET
VITE_STELLAR_NETWORK=TESTNET

# Wallet provider exposed in IDE header (current support: freighter)
VITE_WALLET_PROVIDER=freighter
