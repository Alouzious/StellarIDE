# ── Root Environment Variables ────────────────────────────────────────────────
# Copy this file to .env and fill in your values before running docker compose.

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=stellaride
POSTGRES_USER=stellaride_user
POSTGRES_PASSWORD=secure_password

# ─── Backend ───────────────────────────────────────────────────────────────────
# Use the docker-compose service hostname when running in Docker
DATABASE_URL=postgresql://stellaride_user:secure_password@postgres:5432/stellaride

# For Neon (hosted PostgreSQL), use your Neon connection string instead:
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/stellaride?sslmode=require

# JWT signing secret — min 32 chars, never commit the real value
JWT_SECRET=change-me-to-a-long-random-string-in-production

# JWT token lifetime in hours
JWT_EXPIRY_HOURS=24

# Backend log level
RUST_LOG=backend=info,tower_http=info

# ─── OAuth (optional) ─────────────────────────────────────────────────────────
# GitHub OAuth — create an app at https://github.com/settings/developers
# Callback URL: http://localhost:8080/api/v1/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth — create credentials at https://console.cloud.google.com/
# Authorised redirect URI: http://localhost:8080/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Base URL of the frontend — used to build OAuth success/error redirects
FRONTEND_URL=http://localhost:5173

# ─── AI Chat (optional) ────────────────────────────────────────────────────────
# Groq API key — get one free at https://console.groq.com
GROQ_API_KEY=
# Supported Groq model (default avoids deprecated llama3-8b-8192)
GROQ_MODEL=llama-3.1-8b-instant

# ─── Frontend ──────────────────────────────────────────────────────────────────
# URL of the API (supports base host or full /api/v1 URL)
VITE_API_URL=http://localhost:8080

# Stellar network: TESTNET | MAINNET | FUTURENET
VITE_STELLAR_NETWORK=TESTNET

# Wallet provider enabled in IDE (currently freighter)
VITE_WALLET_PROVIDER=freighter

# ─── Soroban Tooling ────────────────────────────────────────────────────────────
# Execution mode for compile/test/audit services: docker | local
SOROBAN_EXECUTION_MODE=docker
# Docker image used for sandboxed compile/test/deploy/audit commands
SOROBAN_DOCKER_IMAGE=stellaride/soroban-sandbox:latest
# Command timeout in seconds for compile/test/deploy/audit
SOROBAN_TIMEOUT_SECONDS=180
# soroban-sdk version used when IDE files do not include a Cargo.toml
SOROBAN_SDK_VERSION=22.0.5
# Network target and RPC endpoint for deploy checks and CLI flows
SOROBAN_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
# Soroban CLI executable path when running deploy command
SOROBAN_CLI_PATH=soroban
# Optional backend deploy signer for CLI-based deployment
SOROBAN_DEPLOY_SECRET_KEY=
# Audit command executed inside sandbox
SOROBAN_AUDIT_COMMAND=cargo scout-audit
